<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Truth Exposed | Investigative Reality Show</title>

    <!-- CSS LINKING -->
    <link rel="stylesheet" href="style.css">

    <!-- Responsive -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body>

<header>
    <div class="logo">TRUTH EXPOSED</div>
    <nav>
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#initiative">Initiative</a>
        <a href="#framework">Framework</a>
        <a href="#contact">Secure Report</a>
    </nav>
</header>

<!-- HERO SECTION -->
<section class="hero" id="home">
    <div class="hero-content">
        <h1>Expose The <span>Hidden Truth</span></h1>
        <p>
            A cinematic investigative reality initiative uncovering corruption,
            abuse of power, and systemic malpractice through documented evidence
            and responsible journalism.
        </p>
        <a href="#initiative" class="btn">Begin Investigation</a>
    </div>
</section>

<!-- ABOUT -->
<section id="about">
    <h2 class="section-title">About The Initiative</h2>
    <p>
        Truth Exposed is a serious investigative platform focused on transparency,
        accountability, and public awareness. Through structured research,
        confidential reporting systems, and legal verification processes,
        the initiative aims to present fact-based investigative narratives.
    </p>
</section>

<!-- INITIATIVE -->
<section id="initiative">
    <h2 class="section-title">Core Investigation Areas</h2>

    <div class="card-container">
        <div class="card">
            <h3>Political Transparency</h3>
            <p>Analysis of public funds, contracts, and financial inconsistencies.</p>
        </div>

        <div class="card">
            <h3>Whistleblower Protection</h3>
            <p>Confidential systems ensuring identity safety and data security.</p>
        </div>

        <div class="card">
            <h3>Evidence-Based Journalism</h3>
            <p>Verified documentation before any public exposure.</p>
        </div>

        <div class="card">
            <h3>Citizen Awareness</h3>
            <p>Educational content explaining governance and accountability systems.</p>
        </div>
    </div>
</section>

<!-- FRAMEWORK -->
<section id="framework">
    <h2 class="section-title">Investigation Framework</h2>

    <div class="timeline">
        <div class="timeline-item">
            <h4>Phase 1 – Data Collection</h4>
            <p>Collection of documents, financial records, and digital evidence.</p>
        </div>

        <div class="timeline-item">
            <h4>Phase 2 – Verification</h4>
            <p>Cross-checking facts with analysts and legal experts.</p>
        </div>

        <div class="timeline-item">
            <h4>Phase 3 – Documentary Production</h4>
            <p>Structured narrative development with factual backing.</p>
        </div>

        <div class="timeline-item">
            <h4>Phase 4 – Responsible Disclosure</h4>
            <p>Publishing findings with documented transparency.</p>
        </div>
    </div>
</section>

<!-- CONTACT -->
<section id="contact">
    <h2 class="section-title">Secure & Confidential Report</h2>
    <form>
        <input type="text" placeholder="Name (Optional)">
        <input type="email" placeholder="Email (Optional)">
        <textarea rows="6" placeholder="Describe the issue or provide evidence..."></textarea>
        <button type="submit">Submit Securely</button>
    </form>
</section>

<footer>
    © 2026 Truth Exposed | Developed by Tarun Kumar
</footer>

</body>
</html>
<head>
    <title>Truth Exposed</title>
    <link rel="stylesheet" href="style.css">
</head>
